# ─────────────────────────────────────────────────────────────
# Supabase — lấy tại: Dashboard → Project Settings → API
# ─────────────────────────────────────────────────────────────
# URL project (công khai, an toàn để lộ)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# anon / publishable key (CÔNG KHAI — RLS + RPC là lớp bảo vệ, không phải key này)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
# (App KHÔNG cần service_role/secret key — mọi thao tác đã dùng RLS + RPC an toàn.)

# ─────────────────────────────────────────────────────────────
# Thông tin ngân hàng cho QR VietQR (mục 12) — điền số thật của chủ home
# BIN: mã ngân hàng VietQR (vd MB Bank = 970422, Vietcombank = 970436)
# ─────────────────────────────────────────────────────────────
# BIN VietQR: TPBank=970423, MB=970422, VCB=970436, ACB=970416, ...
NEXT_PUBLIC_BANK_BIN=970423
NEXT_PUBLIC_BANK_ACCOUNT=0973900340
# Tên chủ TK cho QR: IN HOA, KHÔNG DẤU
NEXT_PUBLIC_BANK_ACCOUNT_NAME=TRAN NGOC HUNG
# Tên chủ TK hiển thị trong tin nhắn (có dấu)
NEXT_PUBLIC_BANK_ACCOUNT_NAME_DISPLAY=TRẦN NGỌC HÙNG
# Tên ngân hàng hiển thị trong tin nhắn
NEXT_PUBLIC_BANK_NAME=TP BANK - Ngân hàng Tiên Phong

# ─────────────────────────────────────────────────────────────
# URL app (để build link sale /s/{token} tuyệt đối khi cần)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
