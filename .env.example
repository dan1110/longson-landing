# ─────────────────────────────────────────────────────────────
# Supabase — lấy tại: Dashboard → Project Settings → API
# ─────────────────────────────────────────────────────────────
# URL project (công khai, an toàn để lộ)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# anon / publishable key (CÔNG KHAI — RLS + RPC là lớp bảo vệ, không phải key này)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
# service_role / secret key — CHỈ dùng cho tác vụ nền tin cậy (đồng bộ Google Sheet).
# TUYỆT ĐỐI KHÔNG để lộ ra client. Lấy ở Dashboard → Project Settings → API.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ─────────────────────────────────────────────────────────────
# Google Sheet — tự đồng bộ toàn bộ dữ liệu (Khách / Sale / Thu chi)
# Cách lấy (một lần):
#   1. Vào https://console.cloud.google.com → tạo Project (hoặc dùng project sẵn).
#   2. APIs & Services → Enable APIs → bật "Google Sheets API".
#   3. APIs & Services → Credentials → Create Credentials → Service account.
#      Tạo xong, mở service account → tab Keys → Add key → JSON → tải file .json.
#   4. Mở file .json: lấy "client_email" và "private_key" điền xuống dưới.
#   5. Mở Google Sheet đích → Share → dán client_email, cấp quyền "Editor".
#   6. SPREADSHEET_ID là đoạn giữa /d/ và /edit trong URL của sheet.
# ─────────────────────────────────────────────────────────────
# ID của Google Sheet (đoạn giữa /d/.../edit trong URL)
GOOGLE_SHEETS_SPREADSHEET_ID=1mXfuWrzK1_JhBJv2YYQibLeEOrWXIDiEeh6nRe4bPK8
# client_email trong file JSON của service account
GOOGLE_SHEETS_CLIENT_EMAIL=long-son-sheet@ten-project.iam.gserviceaccount.com
# private_key trong file JSON — GIỮ NGUYÊN dấu \n, bọc trong dấu nháy kép.
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ─────────────────────────────────────────────────────────────
# Thông tin ngân hàng cho QR VietQR (mục 12) — điền số thật của chủ home
# BIN: mã ngân hàng VietQR (vd MB Bank = 970422, Vietcombank = 970436)
# ─────────────────────────────────────────────────────────────
# BIN VietQR: TPBank=970423, MB=970422, VCB=970436, ACB=970416, ...
NEXT_PUBLIC_BANK_BIN=970423
NEXT_PUBLIC_BANK_ACCOUNT=0973900340
# Tên chủ TK cho QR: IN HOA, KHÔNG DẤU
NEXT_PUBLIC_BANK_ACCOUNT_NAME=TRAN NGOC HUNG
# Tên chủ TK hiển thị trong tin nhắn (có dấu)
NEXT_PUBLIC_BANK_ACCOUNT_NAME_DISPLAY=TRẦN NGỌC HÙNG
# Tên ngân hàng hiển thị trong tin nhắn
NEXT_PUBLIC_BANK_NAME=TP BANK - Ngân hàng Tiên Phong

# ─────────────────────────────────────────────────────────────
# URL app (để build link sale /s/{token} tuyệt đối khi cần)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
